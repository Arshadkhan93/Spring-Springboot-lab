<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:util="http://www.springframework.org/schema/util"
       xmlns:context="http://www.springframework.org/schema/context"

       xsi:schemaLocation="
        http://www.springframework.org/schema/beans 
        http://www.springframework.org/schema/beans/spring-beans.xsd
        
        http://www.springframework.org/schema/util 
        http://www.springframework.org/schema/util/spring-util.xsd
        
        http://www.springframework.org/schema/context 
        http://www.springframework.org/schema/context/spring-context.xsd">
        
        <bean id="project1" class="lab.bean.Project">
        <constructor-arg value="101"/>
        <constructor-arg value="Web Application"/>
        <constructor-arg value="6 Months"/>
        </bean>
        
        <bean id="project2" class="lab.bean.Project">
        <constructor-arg value="102"/>
        <constructor-arg value="Recruitment System"/>
        <constructor-arg value="4 Months"/>
        </bean>
        
        <bean id="emp1" class="lab.bean.Employee">
        <constructor-arg value="101" />
        <constructor-arg value="Alice" />
        </bean>
        
        <bean id="emp2" class="lab.bean.Employee">
        <constructor-arg value="102" />
        <constructor-arg value="Bob" />
        </bean>
        
        <bean id="dept1" class="lab.bean.Department">
        <constructor-arg value="IT"/>
        <constructor-arg >
        <list >
        <ref bean="emp1"/>
        </list>
        </constructor-arg>
        </bean>
        
        <bean id="dept2" class="lab.bean.Department">
        <constructor-arg value="HR"/>
        <constructor-arg >
        <list >
        <ref bean="emp2"/>
        </list>
        </constructor-arg>
        </bean>
        
        <bean id="com" class="lab.bean.Company">
        <constructor-arg value="TechWave Solutions"/>
        <constructor-arg>
        <map>
        <entry key="IT" value-ref="dept1"></entry>
        <entry key="HR" value-ref="dept2"></entry>
        </map>
        </constructor-arg>
        </bean>
        
        
    <!-- Component Scan -->
    <context:component-scan base-package="lab.bean"/>

</beans>